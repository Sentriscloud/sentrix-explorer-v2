# Sentrix Explorer V2 — environment template.
# Copy to `.env` for local dev; CI/CD reads the same keys from secret stores.

# ── Network selector ────────────────────────────────────────────
# One of: mainnet | testnet
# Compile-time baked into the WASM bundle via option_env! in src/config.rs,
# so a single deploy artifact is per-network, not multi-tenant.
SENTRIX_NETWORK=mainnet

# ── gRPC endpoints (override) ───────────────────────────────────
# Empty = use the network-default in src/config.rs. Override only for
# local-validator dev (e.g. http://127.0.0.1:50051) or staging.
SENTRIX_GRPC_MAINNET=https://grpc.sentrixchain.com
SENTRIX_GRPC_TESTNET=https://grpc-testnet.sentrixchain.com

# ── Leptos site layout ──────────────────────────────────────────
# Match [package.metadata.leptos] in Cargo.toml. cargo-leptos consumes
# these at build time; the SSR binary reads them at runtime.
LEPTOS_SITE_ROOT=target/site
LEPTOS_SITE_PKG_DIR=pkg
LEPTOS_SITE_ADDR=127.0.0.1:3000
LEPTOS_RELOAD_PORT=3001
LEPTOS_ENV=DEV
